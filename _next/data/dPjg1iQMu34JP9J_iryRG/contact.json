{"pageProps":{"page":{"slug":"contact","title":"Contact | Agust Islandia · Agust Smari Bjarkarson","description":"Contact Agust Islandia (Agust Smari Bjarkarson) for press, bookings, Pride festivals, interviews, and features. Email agust@arcticsea.com.","canonical":"/contact.html","routePath":"/contact.html","language":"en-US","og":{"title":"Contact | Agust Islandia · Agust Smari Bjarkarson","description":"Press, booking, and general enquiries for Agust Islandia (Agust Smari Bjarkarson), Icelandic queer pop artist.","image":"/agust_islandia.jpg","type":"website","url":"/contact.html"},"twitter":{"card":"summary_large_image","title":"Contact | Agust Islandia · Agust Smari Bjarkarson","description":"Press, booking, and general enquiries for Agust Islandia.","image":"/agust_islandia.jpg"},"bodyHtml":"<header class=\"hub-hero\">\n      <section class=\"hub-hero-copy\">\n        <span class=\"hub-kicker\">Get in Touch</span>\n        <h1>Contact</h1>\n        <p class=\"hub-subtitle\">\n          Press, bookings, Pride festivals, interviews, features, collaborations, and general\n          enquiries all go to the same email for <strong>Agust Smari Bjarkarson</strong>,\n          performing as <strong>Agust Islandia</strong>. Responses come from Reykjavik.\n        </p>\n        <div class=\"hub-actions\">\n          <a class=\"hub-btn hub-btn-primary\" href=\"mailto:agust@arcticsea.com\">agust@arcticsea.com</a>\n          <a class=\"hub-btn hub-btn-secondary\" href=\"/press.html\">Press page</a>\n          <a class=\"hub-btn hub-btn-secondary\" href=\"/about.html\">Biography</a>\n        </div>\n        <div class=\"hub-highlights\">\n          <div class=\"hub-highlight\">\n            <strong>Booking</strong>\n            <span>Pride festivals, club nights, LGBTQ+ events, live showcases.</span>\n          </div>\n          <div class=\"hub-highlight\">\n            <strong>Press</strong>\n            <span>Interviews, features, music syndication, podcast guests.</span>\n          </div>\n          <div class=\"hub-highlight\">\n            <strong>Collab</strong>\n            <span>Producers, writers, visual artists, queer creators.</span>\n          </div>\n        </div>\n      </section>\n\n      <aside class=\"hub-summary-card\" aria-labelledby=\"contact-summary-title\">\n        <div>\n          <h2 id=\"contact-summary-title\">Quick check</h2>\n          <p>A short note with the essentials helps me respond faster. Please include:</p>\n        </div>\n        <ul>\n          <li>Who you are &amp; what you represent</li>\n          <li>Format: interview, festival, feature, collab</li>\n          <li>Date range or deadline</li>\n          <li>Link to your outlet or event</li>\n        </ul>\n        <div class=\"hub-link-row\">\n          <a class=\"hub-btn hub-btn-secondary\" href=\"mailto:agust@arcticsea.com\">Send an email</a>\n        </div>\n      </aside>\n    </header>\n\n    <main id=\"main-content\" class=\"hub-grid\">\n\n      <section class=\"hub-panel\" aria-labelledby=\"email-heading\">\n        <div class=\"hub-panel-inner\">\n          <h2 id=\"email-heading\">Email</h2>\n          <p>One inbox, one address. English, Icelandic, and Spanish all welcome.</p>\n          <p><strong><a href=\"mailto:agust@arcticsea.com\">agust@arcticsea.com</a></strong></p>\n          <p>For time-sensitive press enquiries, put a deadline in the subject line.</p>\n        </div>\n      </section>\n\n      <section class=\"hub-panel\" aria-labelledby=\"listen-heading\">\n        <div class=\"hub-panel-inner\">\n          <h2 id=\"listen-heading\">Listen &amp; follow</h2>\n          <p>Official profiles on the main streaming and social platforms:</p>\n          <div class=\"hub-link-row\">\n            <a class=\"hub-btn hub-btn-primary\" href=\"https://music.apple.com/us/artist/agust-smari-bjarkarson/1827272561\" target=\"_blank\" rel=\"noopener noreferrer\">Apple Music</a>\n            <a class=\"hub-btn hub-btn-primary\" href=\"https://open.spotify.com/artist/3vCWdArvNjajk3eCmfExNG\" target=\"_blank\" rel=\"noopener noreferrer\">Spotify</a>\n            <a class=\"hub-btn hub-btn-secondary\" href=\"https://www.tiktok.com/@gusticeland\" target=\"_blank\" rel=\"noopener noreferrer\">TikTok</a>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"hub-panel\" aria-labelledby=\"press-heading\">\n        <div class=\"hub-panel-inner\">\n          <h2 id=\"press-heading\">For press</h2>\n          <p>Release milestones, syndication-ready materials, and the latest press release live on the press page.</p>\n          <div class=\"hub-link-row\">\n            <a class=\"hub-btn hub-btn-secondary\" href=\"/press.html\">Press page</a>\n            <a class=\"hub-btn hub-btn-secondary\" href=\"/agust-islandia-gay-and-proud-press-release.html\">Gay and Proud press release</a>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"hub-panel\" aria-labelledby=\"reference-heading\">\n        <div class=\"hub-panel-inner\">\n          <h2 id=\"reference-heading\">Artist reference</h2>\n          <p>Public pages with stable URLs, good for citation in articles and listings.</p>\n          <div class=\"hub-link-row\">\n            <a class=\"hub-btn hub-btn-secondary\" href=\"/about.html\">Biography</a>\n            <a class=\"hub-btn hub-btn-secondary\" href=\"/discography.html\">Discography</a>\n            <a class=\"hub-btn hub-btn-secondary\" href=\"/lyrics.html\">Lyrics archive</a>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"hub-panel hub-panel-wide\" aria-labelledby=\"identifiers-heading\">\n        <div class=\"hub-panel-inner\">\n          <h2 id=\"identifiers-heading\">Artist identifiers</h2>\n          <p>For citation, indexing, and verification across music databases and libraries:</p>\n          <ul>\n            <li><strong>Legal name:</strong> Agust Smari Bjarkarson</li>\n            <li><strong>Stage name:</strong> Agust Islandia</li>\n            <li><strong>Based in:</strong> Reykjavik, Iceland</li>\n            <li><strong>ISNI:</strong> 0000 0005 2809 9919</li>\n            <li><strong>MusicBrainz:</strong> <a href=\"https://musicbrainz.org/artist/fca2294b-5bbb-4711-881a-aa61e90346f5\" target=\"_blank\" rel=\"noopener noreferrer\">fca2294b-5bbb-4711-881a-aa61e90346f5</a></li>\n            <li><strong>Wikidata:</strong> <a href=\"https://www.wikidata.org/wiki/Q136089384\" target=\"_blank\" rel=\"noopener noreferrer\">Q136089384</a></li>\n          </ul>\n        </div>\n      </section>\n    </main>","schemaGraph":{"@context":"https://schema.org","@graph":[{"@type":"ContactPage","@id":"https://www.gusti.com/contact.html#webpage","url":"https://www.gusti.com/contact.html","name":"Contact | Agust Islandia · Agust Smari Bjarkarson","description":"Contact details for press, bookings, and general enquiries for Agust Islandia (Agust Smari Bjarkarson).","isPartOf":{"@id":"https://www.gusti.com/#website"},"about":{"@id":"https://www.gusti.com/#agust-person"},"breadcrumb":{"@id":"https://www.gusti.com/contact.html#breadcrumb"},"publisher":{"@id":"https://www.gusti.com/#organization"},"inLanguage":"en-US"},{"@type":"WebSite","@id":"https://www.gusti.com/#website","name":"Agust Islandia","url":"https://www.gusti.com/","publisher":{"@id":"https://www.gusti.com/#organization"},"inLanguage":"en-US"},{"@type":"Organization","@id":"https://www.gusti.com/#organization","name":"Agust Islandia","url":"https://www.gusti.com/","email":"agust@arcticsea.com","contactPoint":{"@type":"ContactPoint","contactType":"press","email":"agust@arcticsea.com","availableLanguage":["English","Icelandic","Spanish"]},"logo":{"@type":"ImageObject","url":"https://www.gusti.com/android-chrome-192x192.png"},"sameAs":["https://music.apple.com/us/artist/agust-smari-bjarkarson/1827272561","https://open.spotify.com/artist/3vCWdArvNjajk3eCmfExNG","https://musicbrainz.org/artist/fca2294b-5bbb-4711-881a-aa61e90346f5"]},{"@typ